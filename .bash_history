head ~/googledrive-local/.search-text/.drive-map.tsv
#1772892264
fgdw() {
  local idx="$HOME/googledrive-local/.search-text"
  local map="$idx/.drive-map.tsv"

  rg -n --hidden --smart-case      --max-columns 200 --max-columns-preview      "${*:-.}" "$idx" |
  fzf --ansi -d:       --preview 'bat --style=numbers --color=always {1} --line-range {2}:+20'       --bind "enter:execute(
        f={1};
        rel=\${f#$idx/};
        rel=\${rel%.txt};
        id=\$(awk -F '\t' -v p=\"\$rel\" '\$1==p{print \$2; exit}' \"$map\");
        if [ -n \"\$id\" ]; then
          xdg-open \"https://drive.google.com/file/d/\$id/view\";
        fi
      )"
}
